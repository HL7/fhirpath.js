#!/usr/bin/env node

const fp = require('../src/fhirpath');
const util = require('../src/utilities');
const fs = require('fs');
const yaml = require('js-yaml');
const { Command, Option } = require('commander');

const program = new Command();

program
  .description('Parses and/or runs a FHIRPath expression.  If neither --resourceFile nor --resourceJSON is provided, the parse tree of the FHIRPath expression will be output.')
  .addOption(new Option('-b, --basePath <path>', 'base path in the resource from which the JSON data was extracted.'))
  .addOption(new Option('-e, --expression <expr>', 'FHIRPath expression.'))
  .addOption(new Option('-f, --resourceFile <path>', 'A file containing the JSON resource or part of it, if basePath is passed.'))
  .addOption(new Option('-r, --resourceJSON <JSON>', 'JSON resource or part of it, if basePath is passed.'))
  .addOption(new Option('-v, --variables <JSON>', 'JSON hash of variables.'))
  .addOption(new Option('-t, --terminologyUrl <url>', 'the Terminology Service API URL.'))
  .addOption(new Option('-s, --fhirServerUrl <url>', 'the FHIR server URL.'))
  .addOption(new Option('-m, --model <model>', 'Include FHIR model data.')
    .choices(['dstu2', 'stu3', 'r4', 'r5']))
  .addOption(new Option(`-o, --mathMode <mode>`, 'mathematical operations mode.')
    .choices(['native', 'precise']))
  .parse(process.argv);

const options = program.opts();

const expression =  options.expression;
const base =  options.basePath;
if (!expression)
  program.help();
else {
  let resourceJSON = options.resourceJSON;
  if (!resourceJSON) {
    let resourceFile = options.resourceFile;
    if (resourceFile)
      resourceJSON = fs.readFileSync(resourceFile);
  }
  if (!resourceJSON) {
    // Just display the parse tree
    let res = fp.parse(expression);
    console.log('Parse tree for fhirpath(' + expression + ') =>');
    console.log(yaml.dump(res));
  }
  else {
    let context = options.variables;
    if (context)
      context = JSON.parse(context);
    let resource = JSON.parse(resourceJSON);
    let model;

    if (options.model) {
      model = require(`../fhir-context/${options.model}`);
    }
    let res = fp.evaluate(
      resource, base ? {base, expression} : expression, context, model,
      {
        async: true,
        ...(options.terminologyUrl ? {terminologyUrl: options.terminologyUrl} : {}),
        ...(options.fhirServerUrl ? {fhirServerUrl : options.fhirServerUrl} : {}),
        ...(options.mathMode ? {preciseMath : options.mathMode === 'precise'} : {})
      }
    );

    if (res instanceof Promise) {
      res.then((r) => printResult(expression, r))
    } else {
      printResult(expression, res);
    }
  }
}

/**
 * Prints the result to the console.
 * @param {string} expression - input expression
 * @param {Array} result - result of evaluating the expression
 */
function printResult(expression, result) {
  console.log('fhirpath(' + expression + ') =>');
  console.log(util.toJSON(result, " "));
}
